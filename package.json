{
  "name": "seekdeep-discordbot",
  "version": "10.38.50",
  "type": "module",
  "description": "SeekDeep local Discord bot with local chat, vision, image generation, and SearXNG web search.",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "bot": "node index.js",
    "start:standalone": "node scripts/run-python.mjs local_ai_server.py",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "test": "node smoke_test.mjs",
    "smoke": "node smoke_test.mjs",
    "test:e2e": "playwright test",
    "preflight": "node scripts/preflight.mjs",
    "doctor": "node scripts/doctor.mjs",
    "setup:models": "node scripts/run-python.mjs warmup_local_cache.py",
    "setup:chat-models": "node scripts/run-python.mjs warmup_local_cache.py --chat-only",
    "setup:models:optional": "node scripts/run-python.mjs warmup_local_cache.py --include-optional",
    "setup:chat-models:optional": "node scripts/run-python.mjs warmup_local_cache.py --chat-only --include-optional",
    "audit:model-cache": "node scripts/run-python.mjs warmup_local_cache.py --audit-cache --show-unused",
    "prune:model-cache": "node scripts/run-python.mjs warmup_local_cache.py --prune-unused --quarantine",
    "purge:model-cache-quarantine": "node scripts/run-python.mjs warmup_local_cache.py --purge-quarantine"
  },
  "dependencies": {
    "@discordjs/voice": "^0.18.0",
    "discord.js": "^14.18.0",
    "dotenv": "^17.4.2",
    "form-data": "^4.0.1",
    "jszip": "^3.10.1",
    "libsodium-wrappers": "^0.7.13",
    "node-fetch": "^3.3.2",
    "opusscript": "^0.0.8",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
