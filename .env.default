# SeekDeep local Discord bot configuration · MINIMAL first-run template
# ----------------------------------------------------------------------------
# Role: setup_local.ps1 copies this file to .env on first run (only if .env is
# missing). Keep this file lean -- ship only the keys a user MUST set or that
# we want them to see immediately on first run.
#
# Want the full reference with every supported knob (chat tuning, image-gen
# defaults, provider URLs, HF cache paths, etc.)? See .env.example.
#
# Put your real Discord bot token below if this is a fresh rebuild.

DISCORD_TOKEN=
# Discord Application / Client ID from the Developer Portal. Optional for
# message replies, but required for slash + context-menu command registration
# diagnostics. Doctor will WARN (not FAIL) if blank.
DISCORD_CLIENT_ID=

CHAT_PROVIDER=nvidia-local
IMAGE_PROVIDER=nvidia-local
VISION_PROVIDER=nvidia-local
WEB_SEARCH_PROVIDER=searxng

LOCAL_AI_BASE_URL=http://127.0.0.1:7865
SEARXNG_BASE_URL=http://127.0.0.1:8080

# Hugging Face token — needed only for GATED models (Llama, some Gemma).
# Get one at https://huggingface.co/settings/tokens. Accept each gated
# model's license on its page first. Read-only is enough.
HF_TOKEN=

# Ollama — pick one path:
#   1. Local daemon (default) — leave OLLAMA_API_KEY blank, point
#      OLLAMA_BASE_URL at your daemon (default 127.0.0.1:11434).
#   2. Ollama Cloud — paste an API key from https://ollama.com/settings/keys
#      OR run `ollama signin` from the Installer (Step 4) to upload a
#      device ed25519 keypair to your account.
# You can use both: cloud key + local daemon co-exist fine.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_API_KEY=

# Discord bot working dir override. Only used when the Tauri shell spawns
# `node index.js` — the shell runs from %APPDATA%/SeekDeep/app/ where the
# bot files don't exist, so this points at your actual repo (the directory
# that contains index.js + node_modules). Leave blank to auto-detect from
# common clone locations (~/SeekDeep-DiscordBot, ../SeekDeep-DiscordBot).
SEEKDEEP_BOT_CWD=

LOCAL_CHAT_MODEL_ID=meta-llama/Llama-3.1-8B-Instruct
LOCAL_VISION_MODEL_ID=Qwen/Qwen2.5-VL-3B-Instruct
LOCAL_IMAGE_MODEL_ID=Lykon/dreamshaper-xl-1-0

# Optional role-aware chat model selection.
# default_chat falls back to LOCAL_CHAT_MODEL_ID.
# Set any of these to the same value as LOCAL_CHAT_MODEL_ID to disable role routing.
LOCAL_CHAT_FALLBACK_MODEL_ID=ibm-granite/granite-3.3-8b-instruct
LOCAL_CHAT_QUALITY_MODEL_ID=mistralai/Mistral-Nemo-Instruct-2407
LOCAL_CHAT_REASONING_MODEL_ID=microsoft/phi-4
LOCAL_CHAT_LIGHTWEIGHT_MODEL_ID=google/gemma-3n-E4B-it
MODEL_AUTO_FALLBACK=true
MODEL_ROUTER_LOG=true
MODEL_LOG_VRAM=false

# Chat-model quantization. 4bit fits 12-14B models on 24GB VRAM with ~1-2% quality drop.
# Options: 4bit (recommended for laptops), 8bit, none/off (full precision).
LOCAL_CHAT_QUANT=4bit

# Roles that always load at full precision (skip bnb quant).
#
# Empty by default since v10.15. On a 24GB laptop GPU you cannot fit
# Llama-3.1-8B at fp16 (~16 GB) AND SDXL (~7 GB) AND CUDA overhead (~3 GB)
# simultaneously without spilling into Windows shared system memory, which
# transparently destroys desktop responsiveness. Quantizing default_chat
# to 4bit (~5 GB) leaves comfortable headroom for image gen + vision swaps;
# quality drop is ~1-2% on benchmarks.
#
# If you have a desktop GPU with 32GB+ VRAM and want the fp16 nuance back,
# set to: default_chat,fallback_chat
LOCAL_CHAT_QUANT_FULL_ROLES=

LOCAL_MODEL_CACHE_DIR=./models/huggingface
MODEL_KEEP_MODE=task-lru

# Keep models resident in VRAM across task switches. Off by default —
# the task-LRU mode unloads whichever task isn't current. Turn on
# if you have VRAM headroom and want zero reload cost when alternating
# tasks. Chat pin is the biggest win (most frequent model). Explicit
# POST /unload still clears everything regardless of pins.
LOCAL_CHAT_KEEP_RESIDENT=off
LOCAL_VISION_KEEP_RESIDENT=off
LOCAL_IMAGE_KEEP_RESIDENT=off

# VRAM budget: reserve space for OS + background apps, plus safety margin
# for KV cache / allocator fragmentation.  Models that don't fit are queued
# behind the singleflight lock until non-pinned models are evicted.
VRAM_SYSTEM_RESERVE_MB=4096
VRAM_SAFETY_MARGIN_MB=1024

# Let first warmup/download complete. After everything works once, run lock_seekdeep_model_cache_offline.ps1.
HF_LOCAL_FILES_ONLY=false
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0
HF_DATASETS_OFFLINE=0

# Security: allow a Hugging Face model repo to run its OWN Python at load time.
# A few models need it (custom tokenizer/model code); most don't. Leaving it on
# preserves the default behavior for the known-good models. Turn it OFF to harden
# against an untrusted model installed via /model/install executing code in the
# server — models that genuinely require remote code will then fail to load
# loudly instead of running it silently.
SEEKDEEP_TRUST_REMOTE_CODE=on

WEB_AUTO_SEARCH=true
WEB_SEARCH_STRICT_ROUTING=true
WEB_SEARCH_FAIL_OPEN=true
WEB_APPEND_SOURCES=true

MAX_DISCORD_CHARS=1900
SEEKDEEP_MEMORY_MODE=rolling
# Memory scope: "user" keeps each user's conversation separate per channel
# (prevents context bleed between users). "channel" shares one context for
# everyone in a channel (old behavior, better for small private servers).
SEEKDEEP_MEMORY_SCOPE=user
# How many messages to store and how many chars to keep in rolling memory.
# Storage caps (how much is saved): MAX_CONTEXT_MESSAGES / MAX_CONTEXT_CHARS
# Render caps (how much is sent to the model): SEEKDEEP_MEMORY_RECENT_ENTRIES / SEEKDEEP_MEMORY_CONTEXT_CHARS
# Llama-3.1-8B supports 128K tokens; 40K chars ≈ ~12K tokens, well within budget.
#
# CONF-1 CANONICAL SOURCE: these four values are the single source of truth
# for rolling-memory caps. index.js fallbacks, .env.example, and the README
# Conversation-Memory / Tunables tables all mirror these. Render caps stay
# <= store caps so rendering is never capped by the store. If you change a
# value here, update those three mirrors too.
MAX_CONTEXT_MESSAGES=50
MAX_CONTEXT_CHARS=36000
SEEKDEEP_MEMORY_RECENT_ENTRIES=40
SEEKDEEP_MEMORY_CONTEXT_CHARS=28000
SEEKDEEP_IMAGE_PROMPT_MAX_CHARS=650
SEEKDEEP_IMAGE_PROMPT_DYNAMIC_REFINEMENT=true
SEEKDEEP_IMAGE_PROMPT_DYNAMIC_TIMEOUT_MS=180000
SEEKDEEP_IMAGE_PROMPT_DYNAMIC_MAX_TOKENS=160
SEEKDEEP_IMAGE_PROMPT_DYNAMIC_MAX_WORDS=45
SEEKDEEP_IMAGE_PROMPT_DYNAMIC_MAX_CHARS=360

# Image generation quality tuning.
# Guidance scale: how strongly the image follows the prompt. Dreamshaper-XL
# sweet spot is 6.5–8.0. Higher = more prompt-faithful but can over-saturate.
IMAGE_GUIDANCE_SCALE=7.0
# Inference steps: 28 is the standard default. Higher = cleaner but slower.
# /image quality:low|standard|high maps to 12|28|40.
IMAGE_STEPS=28
# Scheduler: dpmsolver++ (DPM++ 2M Karras) is tuned for Dreamshaper-XL.
# Set to "default" to use whatever the model ships with.
IMAGE_SCHEDULER=dpmsolver++

# Upscale defaults. Lanczos + mild unsharp mask is local/offline, fast, and
# avoids a fragile model download. Use realesrgan only after adding the optional
# Python-side model support.
SEEKDEEP_UPSCALE_METHOD=lanczos
SEEKDEEP_UPSCALE_RESAMPLE=lanczos
SEEKDEEP_UPSCALE_SHARPEN=true
SEEKDEEP_UPSCALE_SHARPEN_RADIUS=1.1
SEEKDEEP_UPSCALE_SHARPEN_PERCENT=115
SEEKDEEP_UPSCALE_SHARPEN_THRESHOLD=3
SEEKDEEP_UPSCALE_MAX_OUTPUT_PIXELS=20000000

# Chat generation tuning.
# Dynamic temperature: factual/web-backed queries use CHAT_WEB_TEMPERATURE for
# more coherent synthesis. Creative/general queries keep CHAT_TEMPERATURE.
# CHAT_TOP_K limits sampling to the top K tokens (0 = disabled). Reduces
# low-probability garbage on small models without hurting creativity much.
CHAT_WEB_TEMPERATURE=0.45
CHAT_TOP_K=50
# Web-backed answers get more room to synthesize multiple sources.
CHAT_WEB_MAX_NEW_TOKENS=1536

# Channel gating. Leave SEEKDEEP_ALLOWED_CHANNELS empty for "answer everywhere".
# Both lists are comma-separated channel IDs.
SEEKDEEP_ALLOWED_CHANNELS=
SEEKDEEP_BLOCKED_CHANNELS=

# Direct messages. On (default): a plain typed DM to the bot is treated as a
# chat prompt — full /chat + image + memory pipeline, no @mention needed — and
# bypasses the channel allowlist above. Requires the bot to be a real bot user
# you can DM; uses the DirectMessages gateway intent (requested in code; it is
# NOT privileged, so no Dev-Portal toggle is needed). Set to off to ignore DMs.
SEEKDEEP_DM_CHAT_ENABLED=on

# Desktop app (Tauri shell) close behavior. On (default): the window's X button
# HIDES to the system tray and the bot + AI server keep running in the background
# (the tray icon stays visible so you know it's alive). Right-click the tray icon
# -> "Quit SeekDeep" to fully shut everything down. Set to off (0/false) to make
# the X button quit immediately and sweep every SeekDeep process instead.
SEEKDEEP_CLOSE_HIDES_TO_TRAY=on

# Admins (queue priority + persona/digest commands).
SEEKDEEP_ADMIN_IDS=

# Optional features (require additional setup; all off by default to match
# the code-side fallback in index.js — flip individual flags to `on` if you
# want them enabled at boot). See .env.example for a full-reference variant
# that turns everything on for documentation purposes.
SEEKDEEP_FEATURE_IMG2IMG=off
SEEKDEEP_FEATURE_INSTRUCT_PIX2PIX=off
SEEKDEEP_FEATURE_INPAINT=off
SEEKDEEP_FEATURE_UPSCALE_REALESRGAN=off
SEEKDEEP_FEATURE_NSFW_GATE=off
SEEKDEEP_FEATURE_TTS_VOICE=off

# Optional model overrides for pix2pix / inpaint features.
# Defaults are used when unset: timbrooks/instruct-pix2pix, CIDAS/clipseg-rd64-refined.
#LOCAL_INSTRUCT_PIX2PIX_MODEL_ID=timbrooks/instruct-pix2pix
#LOCAL_CLIPSEG_MODEL_ID=CIDAS/clipseg-rd64-refined

# Gate the "@SeekDeep emoji backup/import/count/list" commands. Defaulted
# off so SeekDeep doesn't collide with demonbot's identical feature in
# shared servers. Flip to "on" to own the vault flow.
SEEKDEEP_FEATURE_EMOJI_VAULT=off

# Gate the right-click "Force React (SeekDeep)" context menu command + the
# paginated emoji picker it opens. Defaulted off for the same
# demonbot-coexistence reason. Flip to "on" to own the force-react flow.
SEEKDEEP_FEATURE_FORCE_REACT=off

# Gate persistent auto-reaction rules per guild (custom @SeekDeep reactrule
# add/list/remove + 5 built-in stacking rules: long_message, forwarded,
# code_block, image_only, link_only). Defaulted off for the same
# demonbot-coexistence reason. When off: per-message rule scan is skipped,
# reactrule admin commands stay out of the dispatch chain. Flip to "on" to
# own the auto-react flow.
SEEKDEEP_FEATURE_AUTO_REACT=off

# Daily digest of bot activity per server. Set the digest channel via
# "@SeekDeep digest channel here" (admin only).
SEEKDEEP_DAILY_DIGEST=off
SEEKDEEP_DAILY_DIGEST_HOUR=9

# Member join/leave log. When JOIN_LEAVE_CHANNEL_ID is set to a text channel
# ID, the bot posts a "Member Joined" / "Member Left" embed (avatar, user
# tag + ID, mention, account-created, server member count, timestamp) on every
# guildMemberAdd / guildMemberRemove event for that channel's guild.
#
# Requires the GuildMembers privileged intent — enable it once at
# https://discord.com/developers/applications -> your bot -> Bot ->
# Privileged Gateway Intents -> Server Members Intent -> Save.
# Without it, the events never fire and nothing is posted.
#
# JOIN_LEAVE_LOGS_ENABLED is the master switch; if left unset it defaults ON
# when a channel ID is present, OFF otherwise. JOIN_LEAVE_LOG_JOINS / _LEAVES
# turn either half off independently. Empty channel ID disables the feature.
JOIN_LEAVE_CHANNEL_ID=
JOIN_LEAVE_LOGS_ENABLED=true
JOIN_LEAVE_LOG_JOINS=on
JOIN_LEAVE_LOG_LEAVES=on

# Various TTLs.
SEEKDEEP_PENDING_IMAGE_PROMPT_TTL_MS=900000
SEEKDEEP_PENDING_IMAGE_SUBJECT_TTL_MS=900000
SEEKDEEP_RECENT_VISION_TARGET_TTL_MS=600000
SEEKDEEP_LAST_SUBJECT_TTL_MS=900000
SEEKDEEP_DYNAMIC_REFINE_CACHE_TTL_MS=600000

# File logging.
SEEKDEEP_FILE_LOGGING=on

# Loading GIF shown in "preparing" / "generating" messages while the user
# waits. Place any small animated GIF at assets/loading.gif (or override).
# Feature is silently disabled when the file is missing.
SEEKDEEP_LOADING_GIF=assets/loading.gif

# Right-click context menu reply visibility. Refine/Translate/Compare default
# to public so everyone can see the result. Set any of these to "on" to make
# that specific command ephemeral (only the clicker sees it).
SEEKDEEP_CONTEXT_REFINE_EPHEMERAL=off
SEEKDEEP_CONTEXT_TRANSLATE_EPHEMERAL=off
SEEKDEEP_CONTEXT_COMPARE_EPHEMERAL=off

# Suppress "Time to Generate / Model Used" footer on fast responses.
# Responses under this threshold (seconds) get no footer. Default: 1.9.
# Set to 0 to always show the footer.
SEEKDEEP_FOOTER_MIN_SECONDS=1.9

# Startup health probe timeout.
SEEKDEEP_STARTUP_HEALTH_TIMEOUT_MS=4000
