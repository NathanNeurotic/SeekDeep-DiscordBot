# SeekDeep local stack defaults: NVIDIA local server + local SearXNG search.
# Existing tokens/keys from the original project are intentionally preserved in this file.
# Replace them later on your machine when you are ready.

DISCORD_TOKEN=REDACTED
GUILD_ID=
ALLOWED_CHANNEL_ID=
ENABLE_MESSAGE_CONTENT=true
SHOW_BALANCE_TO_EVERYONE=true
MAX_OUTPUT_TOKENS=REDACTED
CHAT_TEMPERATURE=0.7
COOLDOWN_MS=5000
REQUEST_TIMEOUT_MS=120000

# Choose: nvidia-local, nim-local, or deepseek
CHAT_PROVIDER=nvidia-local

# DeepSeek cloud settings
DEEPSEEK_API_KEY=REDACTED
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Local NVIDIA NIM settings
NIM_BASE_URL=http://localhost:8001/v1
NIM_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1
NIM_API_KEY=REDACTED
NGC_API_KEY=REDACTED
LOCAL_NIM_CACHE=C:\Users\natha\.cache\nim

# Optional NVIDIA NIM visual settings retained from the original project
NIM_VISUAL_BASE_URL=http://localhost:8002/v1
NIM_VISUAL_MODEL=black-forest-labs/flux.2-klein-4b
HF_TOKEN=REDACTED
IMAGE_PROVIDER=nvidia-local
VISION_PROVIDER=nvidia-local
WEB_SEARCH_PROVIDER=searxng
LOCAL_AI_BASE_URL=http://127.0.0.1:7865
SEARXNG_BASE_URL=http://127.0.0.1:8080
LOCAL_AI_TIMEOUT_MS=600000
LOCAL_CHAT_MODEL_ID=Qwen/Qwen3-8B
LOCAL_VISION_MODEL_ID=Qwen/Qwen2.5-VL-3B-Instruct
LOCAL_IMAGE_MODEL_ID=Lykon/dreamshaper-xl-1-0
LOCAL_MODEL_CACHE_DIR=./models/huggingface
LOCAL_OUTPUT_DIR=./outputs
LOCAL_TEMP_DIR=./temp
MODEL_KEEP_MODE=task-lru
MAX_WEB_RESULTS=5
WEB_AUTO_SEARCH=true
WEB_SEARCH_STRICT_ROUTING=true
WEB_SEARCH_FAIL_OPEN=true
VISION_MAX_VIDEO_FRAMES=6
IMAGE_WIDTH=768
IMAGE_HEIGHT=768
IMAGE_STEPS=30
IMAGE_GUIDANCE_SCALE=6.5
IMAGE_SEED=-1
# SDXL replacement defaults
# If the model is not already cached, first startup will fail while offline-only flags remain enabled.
# Temporarily disable HF_LOCAL_FILES_ONLY / HF_HUB_OFFLINE / TRANSFORMERS_OFFLINE if you need the model to download.

PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
WEB_APPEND_SOURCES=true
HF_LOCAL_FILES_ONLY=true
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
LOCAL_VISION_BACKEND=qwen2_5_vl




SEEKDEEP_PERSONA=neurotic

SEEKDEEP_CENSORSHIP=off


# SEEKDEEP PERSONA OPTIONS
# Swap by changing SEEKDEEP_PERSONA above.
#
# neurotic   = default recommended; sharp, observant, slightly unsettling, controlled
# unsettling = colder and stranger than neurotic, still precise
# clinical   = technical, concise, low-flavor, accuracy-first
# chaotic    = punchier and more irreverent, but still useful
#
# SEEKDEEP CENSORSHIP OPTIONS
# off     = loosest outer bot behavior layer; still cannot guarantee model-weight refusals disappear
# loose   = permissive but with explicit serious-misuse refusals
# minimal = same general intent as loose






















CHAT_REPETITION_PENALTY=1.08

CHAT_NO_REPEAT_NGRAM_SIZE=6

CHAT_ANTI_LOOP_TEMPERATURE=0.20





# Per-user image generation cooldown. 45000 ms = 45 seconds.
SEEKDEEP_IMAGE_COOLDOWN_MS=45000
LOCAL_IMAGE_VARIANT=
IMAGE_USE_SAFETENSORS=true
LOCAL_TORCH_DTYPE=float16
LOCAL_IMAGE_PIPELINE_CLASS=
IMAGE_CFG_NORMALIZATION=false
IMAGE_NEGATIVE_PROMPT=
