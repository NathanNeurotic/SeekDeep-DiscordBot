{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "SeekDeep",
  "version": "../package.json",
  "identifier": "com.nathanneurotic.seekdeep",
  "build": {
    "frontendDist": "../gui",
    "devUrl": "http://127.0.0.1:7865/gui/chat.html",
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "SeekDeep",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "url": "seekdeep-loading.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:*; media-src 'self' data: blob:; worker-src 'self' blob:; frame-src 'none'; frame-ancestors 'none'",
      "dangerousDisableAssetCspModification": ["script-src", "style-src"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "NathanNeurotic",
    "copyright": "© 2026 NathanNeurotic",
    "category": "Productivity",
    "shortDescription": "SeekDeep — local AI assistant (Discord bot + standalone GUI)",
    "longDescription": "SeekDeep is a local-first AI assistant. Runs Llama / Qwen-VL / SDXL (and optionally Ollama / DeepSeek / Anthropic / Gemini) on your own machine. Use it as a Discord bot, or open the standalone GUI and chat directly — same models, same memory, no Discord required.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../local_ai_server.py",
      "../gui_endpoints.py",
      "../warmup_local_cache.py",
      "../package.json",
      "../requirements-local.txt",
      "../requirements-ml.txt",
      "../.env.default",
      "../.env.example",
      "../gui/**/*",
      "../scripts/doctor.mjs",
      "../scripts/preflight.mjs",
      "../scripts/smoke_gui_endpoints.py"
    ],
    "externalBin": [],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "bannerPath": "installer/wix-banner.bmp",
        "dialogImagePath": "installer/wix-dialog.bmp"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/nsis-header.bmp",
        "sidebarImage": "installer/nsis-sidebar.bmp"
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13",
      "exceptionDomain": "127.0.0.1",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
