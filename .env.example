# SeekDeep local Discord bot configuration · FULL env reference
# ----------------------------------------------------------------------------
# Role: documents every supported environment variable with section headers
# and inline comments. Read this when you want to know "is there a knob for X?".
#
# This file is NOT what setup_local.ps1 copies on first run -- that's
# .env.default, the minimum-to-boot subset. Use this file to discover knobs;
# copy the ones you want into your real .env (or into .env.default if you want
# them shipped to fresh installs).
#
# Copy this file to .env and fill in the values below.

# ===========================================================================
# Discord Bot Credentials
# ===========================================================================
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# ===========================================================================
# Provider Routing (nvidia-local, nim-local, deepseek)
# ===========================================================================
CHAT_PROVIDER=nvidia-local
IMAGE_PROVIDER=nvidia-local
VISION_PROVIDER=nvidia-local
WEB_SEARCH_PROVIDER=searxng

# ===========================================================================
# Chat backend: HuggingFace transformers (in-process) or Ollama (daemon)
# ===========================================================================
# LOCAL_CHAT_BACKEND sets the default for every role. Per-role overrides
# below let you mix: e.g. HF for the heavy default_chat (4-bit quantized,
# in-process VRAM management) + Ollama for quality_text (separate daemon,
# zero PyTorch VRAM cost).
#
# When a role is set to 'ollama', its LOCAL_CHAT_<...>_MODEL_ID env is
# interpreted as an Ollama tag (e.g. "llama3:8b") instead of an HF repo ID.
# Ollama tags are auto-pulled by POST /model/warm if not present.
#
# Default 'hf' = backwards-compatible (no change from before this feature).
LOCAL_CHAT_BACKEND=hf
# LOCAL_CHAT_FALLBACK_BACKEND=ollama
# LOCAL_CHAT_QUALITY_BACKEND=ollama
# LOCAL_CHAT_REASONING_BACKEND=ollama
# LOCAL_CHAT_LIGHTWEIGHT_BACKEND=ollama
# LOCAL_CHAT_REFINE_BACKEND=ollama

# ===========================================================================
# OpenAI-compatible REMOTE backend  ***SENDS PROMPTS OFF YOUR BOX***
# ===========================================================================
# Set a chat role's backend to 'openai-compat' to route through any
# hosted provider that speaks /v1/chat/completions. Covers OpenAI itself,
# DeepSeek, Groq, OpenRouter, Together, Mistral La Plateforme, Anyscale,
# Perplexity, and anything else with that endpoint shape.
#
#                      *** PRIVACY WARNING ***
# Roles configured with 'openai-compat' send your prompts AND any chat
# history context OUTSIDE the local machine. The remote provider has its
# own data-handling policy (often including model-training opt-in by
# default). SeekDeep does not, and cannot, control what happens to those
# prompts once they leave 127.0.0.1. Use the local backends (hf/ollama)
# for anything you want to keep off-network.
#
# OpenAI itself     : OPENAI_API_BASE_URL=https://api.openai.com/v1
# DeepSeek          : OPENAI_API_BASE_URL=https://api.deepseek.com/v1
# Groq              : OPENAI_API_BASE_URL=https://api.groq.com/openai/v1
# OpenRouter        : OPENAI_API_BASE_URL=https://openrouter.ai/api/v1
# Together          : OPENAI_API_BASE_URL=https://api.together.xyz/v1
# xAI / Grok        : OPENAI_API_BASE_URL=https://api.x.ai/v1   (model: grok-2-latest, grok-2-1212, etc.)
# Local proxy (LM Studio / vLLM / text-generation-webui openai-mode): set
#   OPENAI_API_BASE_URL to that proxy's URL and leave OPENAI_API_KEY blank
#   if your proxy doesn't require auth. (This is still local; the warning
#   above doesn't apply -- the env name 'OPENAI_*' is just the naming
#   convention.)
#
# OPENAI_API_BASE_URL=
# OPENAI_API_KEY=
# OPENAI_COMPAT_TIMEOUT_SECS=120
# OPENAI_COMPAT_PROBE_TIMEOUT_SECS=5

# Per-role overrides -- put different providers on different roles
# (e.g. fast & cheap default_chat on Groq, premium quality_text on OpenAI):
# LOCAL_CHAT_API_URL=
# LOCAL_CHAT_API_KEY=
# LOCAL_CHAT_QUALITY_API_URL=
# LOCAL_CHAT_QUALITY_API_KEY=
# LOCAL_CHAT_REASONING_API_URL=
# LOCAL_CHAT_REASONING_API_KEY=
# LOCAL_CHAT_LIGHTWEIGHT_API_URL=
# LOCAL_CHAT_LIGHTWEIGHT_API_KEY=
# LOCAL_CHAT_FALLBACK_API_URL=
# LOCAL_CHAT_FALLBACK_API_KEY=
# LOCAL_CHAT_REFINE_API_URL=
# LOCAL_CHAT_REFINE_API_KEY=

# ===========================================================================
# Anthropic native backend  ***SENDS PROMPTS OFF YOUR BOX***
# ===========================================================================
# Distinct from openai-compat -- Anthropic uses /v1/messages with a different
# auth header (x-api-key) and message shape (system at top level). Set a role's
# backend to 'anthropic' and its MODEL_ID to a Claude model name.
#
# Models (examples): claude-3-5-sonnet-20241022, claude-3-5-haiku-20241022,
# claude-3-opus-20240229, claude-3-7-sonnet-latest.
#
# Same privacy warning as openai-compat: prompts leave the box.
#
# ANTHROPIC_API_BASE_URL=https://api.anthropic.com/v1
# ANTHROPIC_API_KEY=
# ANTHROPIC_VERSION=2023-06-01
# ANTHROPIC_TIMEOUT_SECS=120
# ANTHROPIC_PROBE_TIMEOUT_SECS=5

# ===========================================================================
# Google Gemini native backend  ***SENDS PROMPTS OFF YOUR BOX***
# ===========================================================================
# Distinct from both above. Gemini's /v1beta endpoint uses x-goog-api-key auth,
# 'user'/'model' role names (not 'assistant'), and puts the model name in the
# URL path. Set a role's backend to 'gemini' and its MODEL_ID to a Gemini
# model name.
#
# Models (examples): gemini-2.0-flash, gemini-1.5-pro, gemini-1.5-flash,
# gemini-2.5-pro-exp-03-25.
#
# Same privacy warning: prompts leave the box (Google Cloud's policy applies).
#
# GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# GEMINI_API_KEY=
# GEMINI_TIMEOUT_SECS=120
# GEMINI_PROBE_TIMEOUT_SECS=5

# Optional generation tuning -- forwarded when the backend supports it.
# top_p is hardcoded to 0.9 (same as HF default). CHAT_TOP_K +
# CHAT_REPETITION_PENALTY are already used by HF/Ollama; for openai-compat,
# 'frequency_penalty' is the closest equivalent and is forwarded only when
# non-zero.
# CHAT_FREQUENCY_PENALTY=0

# Ollama daemon URL + timeouts. Only consulted when a role is set to ollama.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_SECS=180
OLLAMA_PROBE_TIMEOUT_SECS=2
OLLAMA_PULL_TIMEOUT_SECS=1800
# Hard cap (bytes) on how much the server buffers from a remote chat provider
# (OpenAI-compat / Anthropic / Gemini / Ollama) before parsing the response.
# Guards against a hostile or buggy endpoint streaming a multi-GB body and
# OOM-ing the server. Default 16 MB — well above any real chat completion.
SEEKDEEP_PROVIDER_MAX_RESP_BYTES=16777216
# How long Ollama keeps a model in memory after a request. Same syntax as
# Ollama's own OLLAMA_KEEP_ALIVE: "5m" (default), "1h", "-1"/"infinity" to pin,
# "0" to unload immediately. Mirrors HF's keep-resident behavior at a different
# layer (Ollama VRAM, not PyTorch VRAM -- so doesn't fight the SDXL budget).
OLLAMA_KEEP_ALIVE=5m
# Where the Ollama daemon stores its model files. Read by Ollama itself
# (not by SeekDeep). Set this in the environment that launches `ollama serve`,
# not just in .env -- the daemon needs it before SeekDeep talks to it.
# Default on Windows: %USERPROFILE%\.ollama\models
# OLLAMA_MODELS=

# ===========================================================================
# Model cache paths (where HF / SeekDeep store downloaded model files)
# ===========================================================================
# HuggingFace's own cache root. Defaults to ~/.cache/huggingface on Linux,
# %USERPROFILE%\.cache\huggingface on Windows. Override to put model files
# on a different drive (e.g. D:\models when C: is small). SeekDeep auto-sets
# HF_HOME on startup if not already set; setting it here wins.
# HF_HOME=
# HF_HUB_CACHE=
# Where SeekDeep prefers to snapshot_download into (POST /model/install
# uses this when set; otherwise falls through to HF_HOME).
LOCAL_MODEL_CACHE_DIR=./models/huggingface

# ===========================================================================
# Local AI Server URLs (FastAPI host server + SearXNG search gateway)
# ===========================================================================
LOCAL_AI_BASE_URL=http://127.0.0.1:7865
SEARXNG_BASE_URL=http://127.0.0.1:8080
LOCAL_AI_TIMEOUT_MS=600000
# Ceiling (ms) for the heavy image-pipeline calls (/image /upscale /vision /inpaint).
# Without a bound a stalled backend (e.g. a cold model load under VRAM/CPU pressure)
# hangs the request forever and the "working" loading.gif never clears. Raise it if
# your cold model loads legitimately take longer than this on a busy machine.
LOCAL_AI_IMAGE_TIMEOUT_MS=600000

# ===========================================================================
# Gated API Access Tokens (Hugging Face, DeepSeek, Nvidia NGC)
# ===========================================================================
# Hugging Face token is required to download gated models like Llama 3.1
HF_TOKEN=
HUGGINGFACE_TOKEN=
# DeepSeek API config (for optional deepseek provider)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# Nvidia NIM API keys (for optional nim-local provider)
NIM_BASE_URL=http://localhost:8001/v1
NIM_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1
NIM_API_KEY=
NGC_API_KEY=

# ===========================================================================
# Gated/Model Cache Paths
# ===========================================================================
LOCAL_MODEL_CACHE_DIR=./models/huggingface
HF_HOME=
HF_HUB_CACHE=
TRANSFORMERS_CACHE=

# ===========================================================================
# Local Model Selection
# ===========================================================================
LOCAL_CHAT_MODEL_ID=meta-llama/Llama-3.1-8B-Instruct
LOCAL_VISION_MODEL_ID=Qwen/Qwen2.5-VL-3B-Instruct
LOCAL_IMAGE_MODEL_ID=Lykon/dreamshaper-xl-1-0

# ===========================================================================
# Optional Role-Based Chat Model Selection
# ===========================================================================
# To disable role routing, set these to the same value as LOCAL_CHAT_MODEL_ID
LOCAL_CHAT_FALLBACK_MODEL_ID=ibm-granite/granite-3.3-8b-instruct
LOCAL_CHAT_QUALITY_MODEL_ID=mistralai/Mistral-Nemo-Instruct-2407
LOCAL_CHAT_REASONING_MODEL_ID=microsoft/phi-4
LOCAL_CHAT_LIGHTWEIGHT_MODEL_ID=google/gemma-3n-E4B-it
MODEL_AUTO_FALLBACK=true
MODEL_ROUTER_LOG=true
MODEL_LOG_VRAM=true

# When a code/quality chat turn needs the reasoning/quality model but the image
# queue is busy, the VRAM "fallback" policy would answer from the resident 8B
# instead. With this ON (default), the bot instead holds the reply until the
# image jobs already queued finish, then answers with the better model. Set to
# "off" to always answer immediately with whatever model is currently loaded.
# (Only helps when the image model is evictable — i.e. LOCAL_IMAGE_KEEP_RESIDENT
# is off, the default.)
SEEKDEEP_DEFER_HEAVY_CHAT_FOR_VRAM=on
# Max time (ms) to wait for the image queue to drain before giving up and
# answering with the currently-loaded model. Default 120000 (2 min); min 15000.
SEEKDEEP_DEFER_HEAVY_CHAT_MAX_MS=120000

# ===========================================================================
# VRAM Residency, Quantization, and Budgeting Settings
# ===========================================================================
# Chat-model quantization. Options: 4bit (highly recommended), 8bit, none/off
LOCAL_CHAT_QUANT=4bit
# Roles that bypass quantization (comma-separated, e.g. "default_chat,fallback_chat")
LOCAL_CHAT_QUANT_FULL_ROLES=
# Keep models resident in VRAM to avoid reload lag. When LEFT UNSET, chat now
# auto-defaults to resident on a big GPU (>= LOCAL_KEEP_RESIDENT_AUTO_VRAM_GB)
# so it isn't cold-reloaded after every image/vision task; an explicit on/off
# here always wins. Vision/image stay opt-in.
LOCAL_CHAT_KEEP_RESIDENT=on
LOCAL_VISION_KEEP_RESIDENT=on
LOCAL_IMAGE_KEEP_RESIDENT=off
# Total-VRAM threshold (GB) above which an UNSET LOCAL_CHAT_KEEP_RESIDENT
# defaults to ON (24GB box: chat ~5GB stays loaded alongside on-demand SDXL).
# 20 targets 24GB-class cards; 16GB cards keep evict-on-switch (a pinned chat
# would crowd out SDXL there).
LOCAL_KEEP_RESIDENT_AUTO_VRAM_GB=20
MODEL_KEEP_MODE=task-lru
# VRAM constraints (MB)
VRAM_SYSTEM_RESERVE_MB=4096
VRAM_SAFETY_MARGIN_MB=1024

# ===========================================================================
# Offline Mode
# ===========================================================================
# Once all models are downloaded, toggle these to true to run fully offline
HF_LOCAL_FILES_ONLY=false
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0
# Seconds to cache the GET /models/available HF-cache scan. The scan walks the
# whole model cache (multi-second on a large cache); caching stops the GUI's
# concurrent Bot-config fetches from each re-triggering it (which starved the
# loop and made /config reads show UNKNOWN). 'current' selection stays live.
SEEKDEEP_MODELS_AVAIL_TTL_S=20

# Changelog "Recent commits" cache TTL (seconds). GET /changelog/commits proxies
# the GitHub commits API server-side (the GUI's CSP connect-src is loopback-only)
# and caches the trimmed result this long, so the changelog page doesn't re-hit
# GitHub on every view and we stay under the unauthenticated 60 req/hr limit.
# Set GITHUB_TOKEN to raise that ceiling. Serves stale cache if a refresh fails.
SEEKDEEP_CHANGELOG_COMMITS_TTL_S=300

# ===========================================================================
# Conversational / Memory Tuning
# ===========================================================================
MAX_OUTPUT_TOKENS=1024
CHAT_MAX_NEW_TOKENS=1024
CHAT_TEMPERATURE=0.55
CHAT_REPETITION_PENALTY=1.08
CHAT_NO_REPEAT_NGRAM_SIZE=4
CHAT_ANTI_LOOP_TEMPERATURE=0.20
COOLDOWN_MS=5000
MAX_DISCORD_CHARS=2000

# Rolling chat memory settings
# CONF-1: these mirror .env.default (the canonical source). Store caps =
# 50 entries / 36000 chars; render caps = 40 entries / 28000 chars
# (render <= store so rendering is never starved by the store).
SEEKDEEP_MEMORY_MODE=rolling
SEEKDEEP_MEMORY_SCOPE=user
MAX_CONTEXT_MESSAGES=50
MAX_CONTEXT_CHARS=36000
SEEKDEEP_MEMORY_RECENT_ENTRIES=40
SEEKDEEP_MEMORY_CONTEXT_CHARS=28000
# BOT-1: cap on the number of (channel,user) conversation keys kept in memory
# (LRU — oldest evicted past the cap) so the store can't grow without bound on a
# long-running multi-guild bot. Each key holds up to the window above.
SEEKDEEP_MEMORY_STORE_MAX_KEYS=1000
# Cap (chars) on the rewritten image prompt before it's handed to the
# image pipeline. Longer prompts are truncated mid-sentence.
SEEKDEEP_IMAGE_PROMPT_MAX_CHARS=650

# ===========================================================================
# Web Search & Grounding Settings
# ===========================================================================
WEB_AUTO_SEARCH=true
WEB_SEARCH_STRICT_ROUTING=true
WEB_SEARCH_FAIL_OPEN=true
WEB_APPEND_SOURCES=true
MAX_WEB_RESULTS=12
CHAT_WEB_TEMPERATURE=0.45
CHAT_TOP_K=50
CHAT_WEB_MAX_NEW_TOKENS=1536

# ===========================================================================
# Image Generation Settings (SDXL / img2img)
# ===========================================================================
IMAGE_WIDTH=1024
IMAGE_HEIGHT=1024
IMAGE_STEPS=30
IMAGE_GUIDANCE_SCALE=6.5
IMAGE_SCHEDULER=dpmsolver++
IMAGE_NEGATIVE_PROMPT=
LOCAL_TORCH_DTYPE=float16
IMAGE_USE_SAFETENSORS=true
IMAGE_CFG_NORMALIZATION=false
SEEKDEEP_IMAGE_COOLDOWN_MS=15000
# Per-user cooldown (ms) for `/archive search` — it fetches up to ~600 Discord
# messages per call, so this throttles spam (0 disables). Default 8000.
#SEEKDEEP_ARCHIVE_SEARCH_COOLDOWN_MS=8000

# Image queue caps (BOT-2). Bound the in-memory pending queue so a spammed /image
# (or a runaway caller) cannot grow it without limit. 0 = unlimited. Admin /
# priority jobs and the regenerate/emergency buttons bypass these.
SEEKDEEP_IMAGE_QUEUE_MAX_PENDING=50
SEEKDEEP_IMAGE_QUEUE_MAX_PER_USER=5

# On-disk image scratch cleanup (PYS-4, read by local_ai_server.py). Every image
# endpoint also saves a PNG to outputs/ that is redundant with the base64 payload
# the bot already receives; these cap that dir so a long-running server doesn't
# grow it forever. 0 = unlimited. outputs/ is capped by count + age; temp/ is
# swept by age only (so an in-flight file is never deleted).
SEEKDEEP_OUTPUTS_MAX_FILES=200
SEEKDEEP_OUTPUTS_MAX_AGE_HOURS=72

# Dynamic prompt refinement (AI re-writing of user prompts)
SEEKDEEP_IMAGE_PROMPT_DYNAMIC_REFINEMENT=on
SEEKDEEP_IMAGE_PROMPT_DYNAMIC_TIMEOUT_MS=900000
SEEKDEEP_IMAGE_PROMPT_DYNAMIC_MAX_TOKENS=1024
SEEKDEEP_IMAGE_PROMPT_DYNAMIC_MAX_WORDS=80
SEEKDEEP_IMAGE_PROMPT_DYNAMIC_MAX_CHARS=2000

# ===========================================================================
# Upscaling Settings
# ===========================================================================
SEEKDEEP_UPSCALE_METHOD=lanczos
SEEKDEEP_UPSCALE_RESAMPLE=3
SEEKDEEP_UPSCALE_SHARPEN=unsharp
SEEKDEEP_UPSCALE_SHARPEN_RADIUS=1.5
SEEKDEEP_UPSCALE_SHARPEN_PERCENT=150
SEEKDEEP_UPSCALE_SHARPEN_THRESHOLD=0
SEEKDEEP_UPSCALE_MAX_OUTPUT_PIXELS=20000000

# ===========================================================================
# Channel Gating, Persona, and Administration
# ===========================================================================
# Leave allowed channels empty to allow responses everywhere
SEEKDEEP_ALLOWED_CHANNELS=
SEEKDEEP_BLOCKED_CHANNELS=
SEEKDEEP_ADMIN_IDS=
SEEKDEEP_PERSONA=neurotic
SEEKDEEP_CENSORSHIP=off

# AUD-002 SSRF policy. Intentionally LEFT OFF even in this "everything on"
# reference file — this is a security-loosening switch, not a feature toggle.
# Off = user-supplied URL fetches cannot reach private/loopback/link-local/
# metadata addresses (each redirect re-validated). Only turn on for a trusted
# single-user LAN install that pastes images from its own private network.
SEEKDEEP_FETCH_ALLOW_PRIVATE=off

# ===========================================================================
# Self-update + process security (AUD-001)
# ===========================================================================
# Allow the GUI "Self-update from GitHub" action to hot-patch this install's
# Python from a GitHub ref. off refuses it (HTTP 403) so the install only
# updates via the signed MSI.
SEEKDEEP_SELF_UPDATE_ENABLED=on
# Which refs the self-updater will pull. strict (default) = an immutable release
# tag (vMAJOR.MINOR.PATCH) or a full 40-char commit SHA only; loose also accepts
# `main` + short SHAs. Tightened because the updater overwrites running .py.
SEEKDEEP_SELF_UPDATE_REF_POLICY=strict
# Allow `main` under the strict policy without going fully loose. Off by default.
#SEEKDEEP_SELF_UPDATE_ALLOW_MAIN=off
# Require a valid maintainer Ed25519 signature before applying a self-update
# (see RELEASE_SIGNING.md). Off so unsigned releases still update; a present-but-
# INVALID signature is always refused regardless of this flag.
SEEKDEEP_SELF_UPDATE_REQUIRE_SIGNATURE=off
# Allow a Hugging Face model repo to run its OWN Python at load time. Default OFF
# (secure-by-default): an untrusted /model/install model can't execute code in
# the server; a model that genuinely requires remote code fails loudly. Set to
# `on` only after you trust that repo.
SEEKDEEP_TRUST_REMOTE_CODE=off

# ===========================================================================
# Other knobs (mirrors .env.default so .env.example stays a strict superset —
# see MAINTAINER.md 4.4)
# ===========================================================================
# Ollama Cloud API key (blank = local daemon at OLLAMA_BASE_URL only).
OLLAMA_API_KEY=
# Discord bot working-dir override for the Tauri shell (blank = auto-detect the
# repo dir that holds index.js + node_modules).
SEEKDEEP_BOT_CWD=
# SearXNG container image the launcher runs (pin a tag/digest for reproducibility).
SEEKDEEP_SEARXNG_IMAGE=searxng/searxng:latest
# Treat a plain typed DM to the bot as a chat prompt (off = ignore DMs).
SEEKDEEP_DM_CHAT_ENABLED=on
# Tauri X button hides to tray + keeps running (off = quit + sweep all processes).
SEEKDEEP_CLOSE_HIDES_TO_TRAY=on
# Member join/leave logging. Set a channel ID to enable; LOGS_ENABLED is the
# master switch, JOINS/_LEAVES gate each half. Needs the GuildMembers intent.
JOIN_LEAVE_CHANNEL_ID=
JOIN_LEAVE_LOGS_ENABLED=true
JOIN_LEAVE_LOG_JOINS=on
JOIN_LEAVE_LOG_LEAVES=on

# ===========================================================================
# Optional Feature Flags (require additional Python/model dependencies)
# ===========================================================================
SEEKDEEP_FEATURE_IMG2IMG=on
SEEKDEEP_FEATURE_INSTRUCT_PIX2PIX=on
SEEKDEEP_FEATURE_INPAINT=on
SEEKDEEP_FEATURE_UPSCALE_REALESRGAN=off
# Real-ESRGAN weights (only used when the flag above is 'on'). Wired — set this
# to a .pth to enable; model NOT bundled. With the flag on but no usable
# weights/deps, /upscale silently falls back to the built-in Lanczos upscale.
#SEEKDEEP_REALESRGAN_MODEL_PATH=C:\path\to\RealESRGAN_x4plus.pth
# Optional arch name when the .pth filename doesn't reveal it (e.g.
# RealESRGAN_x4plus, RealESRGAN_x4plus_anime_6B). Inferred from the filename
# when unset.
#SEEKDEEP_REALESRGAN_MODEL_NAME=RealESRGAN_x4plus
# High-fidelity inpaint auto-masks via GroundingDINO + SAM (vs the default
# CLIPSeg). ~3.2 GB of models (auto-downloaded on first use) and needs CUDA.
# VRAM-budget-gated: if it won't fit it silently falls back to CLIPSeg, so
# turning it 'on' is safe to try even on a busy GPU.
SEEKDEEP_FEATURE_SAM_SEGMENT=off
SEEKDEEP_FEATURE_NSFW_GATE=off
SEEKDEEP_FEATURE_TTS_VOICE=off

# --- Text-to-speech (/tts endpoint + GUI voice reader) ---------------------
# TTS is wired. Point one of these at a voice/model and /tts works; until then
# /tts returns 503 (tts-not-configured). NO voice model is bundled — download
# a Piper .onnx voice yourself (https://github.com/OHF-Voice/piper).
# Engine: 'piper' (fast, offline ONNX — default) or 'xtts' (Coqui XTTS-v2).
SEEKDEEP_TTS_ENGINE=piper
# Piper voice: absolute path to a .onnx voice file (its .onnx.json must sit
# beside it). Leave blank to keep /tts disabled.
#SEEKDEEP_TTS_PIPER_VOICE=C:\path\to\en_US-lessac-medium.onnx
# Optional: a `piper` executable to use instead of the Python package
# (auto-discovered on PATH if the `piper` package isn't importable).
#SEEKDEEP_TTS_PIPER_BIN=
# XTTS model id (only used when SEEKDEEP_TTS_ENGINE=xtts).
#SEEKDEEP_TTS_MODEL_ID=tts_models/multilingual/multi-dataset/xtts_v2
# XTTS target language (only used by the xtts engine).
#SEEKDEEP_TTS_XTTS_LANGUAGE=en
# Hard cap on a single /tts request's text length (chars); above this -> 400.
#SEEKDEEP_TTS_MAX_CHARS=2000

# Optional model overrides for the pix2pix / inpaint features (uncomment to
# pin specific HF repos; commented out keeps the in-code defaults).
#LOCAL_INSTRUCT_PIX2PIX_MODEL_ID=timbrooks/instruct-pix2pix
#LOCAL_CLIPSEG_MODEL_ID=CIDAS/clipseg-rd64-refined
# SAM segmentation models (only used when SEEKDEEP_FEATURE_SAM_SEGMENT=on).
# Wired — point these at local model dirs/files to enable; models NOT bundled.
# When set they override the HF repo ids below; on any miss the inpaint mask
# silently falls back to CLIPSeg.
#SEEKDEEP_SAM_MODEL_PATH=C:\path\to\sam-vit-huge
#SEEKDEEP_GROUNDINGDINO_MODEL_PATH=C:\path\to\grounding-dino-base
# Optional GroundingDINO config (only some checkpoints need it; ignored if it
# fails to parse).
#SEEKDEEP_GROUNDINGDINO_CONFIG_PATH=C:\path\to\GroundingDINO_SwinB.cfg.py
# Fallback HF repo ids (auto-download on first use when the *_PATH knobs above
# are unset). Drop SAM to facebook/sam-vit-large (~1.2GB) or -base (~0.4GB) on
# smaller GPUs.
#LOCAL_SAM_MODEL_ID=facebook/sam-vit-huge
#LOCAL_GROUNDING_DINO_MODEL_ID=IDEA-Research/grounding-dino-base
#SEEKDEEP_SAM_BOX_THRESHOLD=0.25
#SEEKDEEP_SAM_TEXT_THRESHOLD=0.25
#VRAM_EST_SAM_SEGMENT=4400
SEEKDEEP_FEATURE_EMOJI_VAULT=off
SEEKDEEP_FEATURE_FORCE_REACT=off
# GUI->bot command bridge: lets Control Center relay whitelisted, read-only
# commands (ping/status/guilds) to the running bot over the /events WebSocket.
# Off by default; gates BOTH the Python POST /bot/command endpoint (404 when off)
# and the bot's outbound WS client (no socket opened when off).
SEEKDEEP_FEATURE_BOT_BRIDGE=off
SEEKDEEP_FEATURE_AUTO_REACT=off
# When someone archives a user's image via context menu or reply-with-"archive",
# the bot adds a 📥 reaction to the source message so the original author sees
# their image was noticed. Self-archives + bot-source archives skip this
# regardless. Default on; flip to "off" to fully silence.
# (Superseded by data/archive-config.json when present — see GUI Control Center
# → Archive pane. Env flag is the fallback when no config file exists.)
SEEKDEEP_UNIVERSAL_ARCHIVE_NOTIFY=on
# Max age (in days) of a shared #prompts template before `template edit` falls
# back from edit-in-place to tombstone-and-repost. Designer's spec: 14d.
# Constrained to [1, 365] at runtime.
SEEKDEEP_PROMPTS_RESHARE_MAX_AGE_DAYS=14
SEEKDEEP_DAILY_DIGEST=off
SEEKDEEP_DAILY_DIGEST_HOUR=9

# ===========================================================================
# Caches, TTLs, and Logging
# ===========================================================================
SEEKDEEP_PENDING_IMAGE_PROMPT_TTL_MS=900000
SEEKDEEP_PENDING_IMAGE_SUBJECT_TTL_MS=900000
SEEKDEEP_RECENT_VISION_TARGET_TTL_MS=600000
SEEKDEEP_LAST_SUBJECT_TTL_MS=900000
SEEKDEEP_DYNAMIC_REFINE_CACHE_TTL_MS=600000
SEEKDEEP_FILE_LOGGING=on
SEEKDEEP_LOADING_GIF=assets/loading.gif
SEEKDEEP_STARTUP_HEALTH_TIMEOUT_MS=4000
SEEKDEEP_FOOTER_MIN_SECONDS=1.9

# Ephemeral settings for right-click context menus
SEEKDEEP_CONTEXT_REFINE_EPHEMERAL=off
SEEKDEEP_CONTEXT_TRANSLATE_EPHEMERAL=off
SEEKDEEP_CONTEXT_COMPARE_EPHEMERAL=off

# ===========================================================================
# Additional knobs (previously code-only; now surfaced in All Settings)
# ===========================================================================

# Let image generation pull live web context to ground prompts.
SEEKDEEP_IMAGE_WEB_GROUNDING=true

# Auto-refine terse image prompts into richer ones before generating.
SEEKDEEP_IMAGE_PROMPT_REFINEMENT=true

# Offer a pre-generation prompt choice/confirmation step before drawing.
SEEKDEEP_PREGEN_PROMPT_CHOICE=true

# Name of the per-server image-archive channel the bot creates/uses.
SEEKDEEP_ARCHIVE_CHANNEL_NAME=seekdeep-archive

# Keep the Discord bot running even if the local AI server is down.
SEEKDEEP_KEEP_BOT_WITHOUT_AI_SERVER=off

# Log GPU / VRAM stats to the bot log.
SEEKDEEP_GPU_LOGGING=off

# Live-stream each log line over the event bus so the GUI Logs viewer updates
# instantly (on) instead of polling /logs/tail every 3s (off). Small overhead.
SEEKDEEP_EMIT_LOG_LINES=off

# ===========================================================================
# Complete env reference — advanced / internal knobs (DUP-3)
# ===========================================================================
# Every remaining env var the code reads, surfaced so this file is a COMPLETE
# reference (the preflight `env-coverage` guard enforces it). All are OPTIONAL;
# the code default is shown. Uncomment only to override. Grouped by subsystem.

# --- Discord / admin / GUI auth ---
# ADMIN_USER_IDS=                       # comma-separated admin user IDs (alias of SEEKDEEP_ADMIN_IDS)
# CLIENT_ID=                            # Discord client/app ID (fallback for DISCORD_CLIENT_ID)
# DISCORD_REST_RETRIES=3                # retries for Discord REST calls
# DISCORD_REST_TIMEOUT_MS=120000        # per-request Discord REST timeout (ms)
# SEEKDEEP_GUI_TOKEN=                   # GUI/API auth token (auto-generated into .env on first boot if blank)
# SEEKDEEP_GUI_AUTH_ALLOW_OPEN=         # set =1 to bypass the LOCAL AI SERVER's token check (DANGEROUS; dev only). GUI-write disable is SEEKDEEP_GUI_TOKEN_DISABLED.

# --- Chat sampling + prompt refinement ---
# CHAT_TOP_P=0.9                        # nucleus sampling top-p
# LOCAL_CHAT_REFINE_MODEL_ID=           # model for the refine role (defaults to the lightweight chat model)
# REFINE_MAX_NEW_TOKENS=0               # max new tokens for refine passes (0 = auto)
# REFINE_TEMPERATURE=0.72               # temperature for refine passes
# SEEKDEEP_DYNAMIC_REFINE_CACHE_MAX=64               # max cached dynamic-refine results
# SEEKDEEP_IMAGE_PROMPT_DYNAMIC_TEMPERATURE=0.5      # temperature for dynamic image-prompt rewriting

# --- Local AI server: input limits + model cache ---
# LOCAL_AI_DEBUG_PATHS=off              # log resolved model/cache paths on load
# LOCAL_AI_MAX_B64_CHARS=               # cap on inbound base64 image chars (auto: ~1.4x LOCAL_AI_MAX_IMAGE_BYTES)
# LOCAL_AI_MAX_CONTEXT_CHARS=120000     # max chat-context chars accepted by /chat
# LOCAL_AI_MAX_IMAGE_BYTES=25165824     # max inbound image bytes (24 MiB)
# LOCAL_AI_MAX_IMAGE_PIXELS=36000000    # max inbound image pixels (decompression-bomb guard)
# LOCAL_AI_MAX_MESSAGE_CHARS=20000      # max chars per chat message
# LOCAL_AI_MAX_PROMPT_CHARS=20000       # max chars per image/vision prompt
# SEEKDEEP_CHAT_MAX_INPUT_CHARS=200000  # hard char cap before chat tokenization (PYS-3)
# SEEKDEEP_CHAT_MAX_INPUT_TOKENS=16384  # truncation token cap for chat input (PYS-3)
# SEEKDEEP_MODEL_CACHE_DIR=             # override the HF/model cache dir (else LOCAL_MODEL_CACHE_DIR)
# SEEKDEEP_VRAM_PRESSURE_MODE=fallback  # behavior under VRAM pressure: fallback | warn | force-evict

# --- Image generation ---
# IMAGE_IMG2IMG_GUIDANCE_SCALE=5.0      # guidance scale for img2img
# LOCAL_IMAGE_PIPELINE_CLASS=           # override the diffusers pipeline class
# LOCAL_IMAGE_VARIANT=                  # model weights variant (e.g. fp16)
# SEEKDEEP_IMAGE_CACHE_TTL_HOURS=24     # how long generated-image action state is retained
# SEEKDEEP_IMAGE_CONTEXT_TTL_MS=600000  # TTL for "this image" follow-up context (10 min)
# SEEKDEEP_IMAGE_GROUNDING_MAX_TOKENS=320            # max tokens for image-prompt grounding
# SEEKDEEP_IMAGE_NEGATIVE_PROMPT=       # default negative prompt (falls back to IMAGE_NEGATIVE_PROMPT)
# SEEKDEEP_IMAGE_PROMPT_REFINEMENT_LOG=true          # log dynamic image-prompt refinement decisions
# SEEKDEEP_UPSCALE_REALESRGAN_FALLBACK=off           # fall back to Real-ESRGAN when lanczos upscaling is off

# --- Archive subsystem ---
# SEEKDEEP_ARCHIVE_ADOPT_NAMED_CHANNEL=false         # adopt an existing channel matching the archive name
# SEEKDEEP_ARCHIVE_ALLOW_GLOBAL_CHANNEL=false        # allow a single global archive channel
# SEEKDEEP_ARCHIVE_AUTO_CREATE_CHANNEL=false         # auto-create the archive channel if missing
# SEEKDEEP_ARCHIVE_CHANNEL_ID=          # explicit archive channel ID
# SEEKDEEP_ARCHIVE_COUNT_BACKFILL_MAX_PAGES=10       # max history pages scanned for the archive counter
# SEEKDEEP_ARCHIVE_DEDUPE_MAX_PAGES=10  # max history pages scanned for dedupe
# SEEKDEEP_ARCHIVE_THREAD_BULLET=•      # bullet glyph in archive thread summaries
# SEEKDEEP_ARCHIVE_THREAD_EMOJI=🪙      # emoji prefix on archive threads
# SEEKDEEP_UNIVERSAL_ARCHIVE_NOTIFY_EMOJI=📥          # reaction emoji that triggers universal archive-notify

# --- Process lifecycle / watchdog (mostly Tauri-shell + GUI launcher) ---
# SEARXNG_PORT=                         # port the bundled SearXNG container binds
# SEEKDEEP_AUTOSTART_BOT=on             # GUI auto-starts the Discord bot on launch
# SEEKDEEP_AUTO_START_SEARXNG=1         # GUI auto-starts the SearXNG container
# SEEKDEEP_BOT_AI_GRACE_MISSES=10       # health-probe misses tolerated before the bot is considered down
# SEEKDEEP_BOT_AI_PROBE_MS=15000        # interval between bot→AI-server health probes
# SEEKDEEP_BOT_EXIT_RESTART_COOLDOWN_S=30            # cooldown before the watchdog respawns a crashed bot
# SEEKDEEP_BOT_EXIT_RESTART_MAX=3       # max consecutive watchdog respawns before giving up
# SEEKDEEP_BOT_WATCHDOG_STARTUP_GRACE_S=60           # startup grace before the watchdog starts probing
# --- AI-server self-healing (event-loop wedge detector) ---
# An off-loop daemon thread dumps all stacks + force-exits (code 70) if the
# server's asyncio loop wedges; scripts/run-ai-server.ps1 then restarts it.
# SEEKDEEP_LOOP_WATCHDOG=on              # set off to disable the wedge detector entirely
# SEEKDEEP_LOOP_WATCHDOG_STALL_S=30      # loop stall (s) past which a wedge is declared
# SEEKDEEP_LOOP_WATCHDOG_STARTUP_GRACE_S=120          # grace (s) for the loop to come alive at boot
# SEEKDEEP_LOCAL_AI_BOOT_LITE=off       # boot the AI server without preloading heavy models
# SEEKDEEP_REPO_DIR=                    # override the repo dir the GUI runs git/self-update against

# --- Deep-research command ---
# SEEKDEEP_RESEARCH_MAX_TOKENS=2400     # token budget for a research answer
# SEEKDEEP_RESEARCH_FOLLOWUP_MAX_TOKENS=2400         # token budget for a research follow-up
# SEEKDEEP_RESEARCH_TABLE_MAX_TOKENS=2400            # token budget for a research comparison table
# SEEKDEEP_PENDING_RESEARCH_TASK_TTL_MS=2700000      # how long a pending research task is remembered (45 min)

# --- Web search routing ---
# WEB_SEARCH_BLOCKLIST=                 # comma-separated domains to drop from results
# WEB_SEARCH_PREFERRED_DOMAINS=         # comma-separated domains to boost
# WEB_SEARCH_REQUIRE_SOURCES_FOR_NEWS=on             # require cited sources before answering news queries

# --- User-URL fetch policy (SSRF guard; see SECURITY.md) ---
# SEEKDEEP_FETCH_DEFAULT_MAX_BYTES=52428800          # max bytes fetched from a user URL (50 MiB)
# SEEKDEEP_FETCH_DEFAULT_TIMEOUT_MS=30000            # per-fetch timeout (ms)
# SEEKDEEP_FETCH_MAX_REDIRECTS=5        # max redirects followed (each re-validated)

# --- Cross-process file lock (COUP-1) ---
# SEEKDEEP_FILE_LOCK_TIMEOUT_MS=2000    # wait before failing open on a contended data/*.json lock
# SEEKDEEP_FILE_LOCK_STALE_MS=15000     # steal a lock whose holder looks crashed after this long

# --- Self-update / release verification (see RELEASE_SIGNING.md) ---
# SEEKDEEP_SELF_UPDATE_MAX_API_BYTES=8388608         # cap on a GitHub API listing response (8 MiB)
# SEEKDEEP_SELF_UPDATE_MAX_FILE_BYTES=26214400       # cap on a single self-update file (25 MiB)
# SEEKDEEP_SELF_UPDATE_MAX_TREE_ENTRIES=200          # cap on files fetched per subtree (gui/, scripts/) — anti fetch-storm
# SEEKDEEP_RELEASE_SIGNING_PUBKEY=      # Ed25519 pubkey (hex) for update verification (alias of RELEASE_SIGNING_PUBKEY_HEX)

# --- Internal timeouts, TTLs, rate limits + misc caps ---
# SEEKDEEP_DEBUG=off                    # extra debug logging across bot + server
# SEEKDEEP_CONTEXT_GENERATE_IMAGE_GUARD_MS=8000      # debounce on the context-menu "generate image" action
# SEEKDEEP_EMERGENCY_SEEN_TTL_MS=300000              # dedupe window for emergency-button events
# SEEKDEEP_EVENT_TTL_MS=120000          # event-bus message TTL
# SEEKDEEP_FINAL_REPLY_TTL_MS=180000    # dedupe window for final replies
# SEEKDEEP_FORCE_REACT_TTL_MS=600000    # TTL for force-react picker state
# SEEKDEEP_FORCE_REACT_DEFAULT_CAP=3    # default max reactions/user/message (cumulative; per-guild override in data/force-react-config.json; clamped 1-20)
# SEEKDEEP_PROMPT_TTL_MS=30000          # TTL for pending prompt state
# SEEKDEEP_GPU_LOG_INTERVAL_SECONDS=5   # interval between background GPU log samples
# SEEKDEEP_GPU_WATCH_TOTAL_BUDGET_MS=120000          # total budget for a /gpu watch session
# SEEKDEEP_LOG_LINE_RATE_PER_SEC=10     # rate cap on emitted log lines
# SEEKDEEP_MAX_PROMPT_TEMPLATES=25      # per-user saved prompt-template cap
# SEEKDEEP_MAX_UPLOAD_LIMIT_BYTES=0     # extra upload-size cap (0 = use Discord's limit)
# SEEKDEEP_REACT_MATCH_MAX_CHARS=2000   # max content chars an auto-react regex is tested against (BOT-1)
# SEEKDEEP_STATUS_HEALTH_TIMEOUT_MS=8000             # timeout for the /status health probe
# SEEKDEEP_TYPING_INTERVAL_MS=8000      # how often the typing indicator refreshes
# SEEKDEEP_TYPING_MAX_MS=120000         # max time the typing indicator is held
# SEEKDEEP_USER_FACTS_MAX=25            # max remembered facts per user
# SEEKDEEP_USER_FACT_MAX_CHARS=500      # max chars per remembered fact

# --- Tauri desktop shell (read by the Rust shell that spawns the AI server + bot) ---
# SEEKDEEP_PYTHON=                      # interpreter the shell launches the AI server with (else auto-detected venv/system python)
# SEEKDEEP_TAURI_KEEP_BOT_ON_EXIT=off   # keep the Discord bot running after the desktop app exits (default: kill it)
# SEEKDEEP_TAURI_REUSE_SIDECAR=off      # reuse an already-running AI-server sidecar instead of respawning it
