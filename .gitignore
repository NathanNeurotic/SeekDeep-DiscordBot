# SeekDeep gitignore — keep local state, generated artifacts, model caches,
# and secrets out of the public repository.

# ---------------------------------------------------------------------------
# Environment files / secrets
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.backup*
.env.bak*
.env.broken*
!.env.example
!.env.default

keys.txt
key.txt
*keys*.txt
*secret*
*token*
*credential*
*password*
*.pem
*.key
*.p12
*.pfx
credentials*.json
service-account*.json
discord*.json

# ---------------------------------------------------------------------------
# Python environments, bytecode, and build output
# ---------------------------------------------------------------------------
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
build/
dist/

# ---------------------------------------------------------------------------
# Node / frontend build output
# ---------------------------------------------------------------------------
node_modules/
out/
.next/
.turbo/

# ---------------------------------------------------------------------------
# Local AI model/cache bulk
# ---------------------------------------------------------------------------
models/
model/
huggingface/
.cache/
cache/
ollama/

# ---------------------------------------------------------------------------
# Runtime/generated data
# ---------------------------------------------------------------------------
outputs/
outputs_old/
output/
generated/
generations/
saved_generations/
tmp/
temp/
logs/
backups/
checkpoints/
diagnostics/
SeekDeep-publish-audit-*.txt
.previous_chat_model.txt
# Self-update sentinel — written by POST /system/self-update so the Tauri
# extractor knows not to clobber hot-patched files on next boot. Per-install
# state, never commit.
.self-updated
# Self-update staging dirs (transient). Wiped at start of every run, but
# if a process dies mid-update the orphan stays until next run.
.self-update-staging-*

# Local Discord/server state. These are user/server-specific runtime files,
# not distributable defaults.
data/server-stats.json
data/archive-guild-config.json
data/archive-guild-config.json.bak*
data/archive-config.json
data/archive-optout.json
data/archive-snapshot.json
data/memory-presets.json
data/prompt-templates.json
data/user-facts.json
data/persona-overrides.json
data/custom-personas.json
data/auto-reactions.json
data/bot-status.json
data/system-state.json
data/pending-image-prompts.json
!data/.gitkeep

# Playwright (audit §12) — local browser-driven Control Center smoke.
test-results/
playwright-report/
.playwright/
server.log
server.pid

# Personal scratch from AI/audit sessions — never publish.
AUDIT*.md
REPO_AUDIT*.md

# Stale clipboard/screenshot uploads. The repo had 31 of these tracked
# with zero documentation references (antigravity AUD-006). Existing
# tracked blobs were removed with `git rm --cached` in commit `<future>`;
# this rule keeps new ones out.
docs/uploads/
gui/uploads/

# Tauri build artifacts (Rust target dir + generated schemas)
src-tauri/target/
src-tauri/gen/
src-tauri/WixTools/

# ---------------------------------------------------------------------------
# Agent/tool workspaces and one-off repair artifacts
# ---------------------------------------------------------------------------
.claude/
.agents/
.codex/
.gemini/
.antigravity/
patches/
handoff/
agents/
patch_*.py
apply_*.ps1
repair_*.py
fix_*.py
force_fix_*.py

# ---------------------------------------------------------------------------
# Archives / binary bundles created during release or local testing
# ---------------------------------------------------------------------------
*.zip
*.7z
*.rar
*.tgz
*.tar
*.tar.gz

# ---------------------------------------------------------------------------
# Legacy broken git directory backups
# ---------------------------------------------------------------------------
.git.broken_*

# ---------------------------------------------------------------------------
# Editor / OS noise / scratch files
# ---------------------------------------------------------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*.log
*.tmp
*.bak
*.bak.*
*.bak-*
*.backup
*.backup*
d2utmp*
