# SeekDeep gitignore — keep large/local/secret artifacts out of git.

# Secrets and local config
.env
.env.local
.env.backup*
.env.bak*
.env.broken*
keys.txt

# Python venv / bytecode
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# Node
node_modules/

# Local data / runtime state
models/
outputs/
outputs_old/
saved_generations/
temp/
logs/
backups/
checkpoints/
diagnostics/
.previous_chat_model.txt
data/server-stats.json
data/archive-guild-config.json
data/archive-guild-config.json.bak*

# Old broken git directory (renamed during init)
.git.broken_*

# Legacy patch / backup artifacts (pre-git development)
patches/
handoff/
agents/
patch_*.py
apply_*.ps1
repair_*.py
fix_*.py
force_fix_*.py
*.bak
*.bak.*
*.bak-*
*.backup*
d2utmp*

# Claude Code workspace (local-only settings + worktrees)
.claude/

# Editor / OS noise
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo

# Python build / packaging
*.egg-info/
build/
dist/

# Misc
*.log
*.tmp
