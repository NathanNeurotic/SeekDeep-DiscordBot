# SeekDeep gitignore — keep local state, generated artifacts, model caches,
# and secrets out of the public repository.

# ---------------------------------------------------------------------------
# Environment files / secrets
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.backup*
.env.bak*
.env.broken*
!.env.example
!.env.default

keys.txt
key.txt
*keys*.txt
*secret*
*token*
*credential*
*password*
*.pem
*.key
*.p12
*.pfx
credentials*.json
service-account*.json
discord*.json

# ---------------------------------------------------------------------------
# Python environments, bytecode, and build output
# ---------------------------------------------------------------------------
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
build/
dist/

# ---------------------------------------------------------------------------
# Node / frontend build output
# ---------------------------------------------------------------------------
node_modules/
out/
.next/
.turbo/

# ---------------------------------------------------------------------------
# Local AI model/cache bulk
# ---------------------------------------------------------------------------
models/
model/
huggingface/
.cache/
cache/
ollama/

# ---------------------------------------------------------------------------
# Runtime/generated data
# ---------------------------------------------------------------------------
outputs/
outputs_old/
output/
generated/
generations/
saved_generations/
tmp/
temp/
logs/
backups/
checkpoints/
diagnostics/
SeekDeep-publish-audit-*.txt
.previous_chat_model.txt

# Local Discord/server state. These are user/server-specific runtime files,
# not distributable defaults.
data/server-stats.json
data/archive-guild-config.json
data/archive-guild-config.json.bak*
data/archive-config.json
data/archive-optout.json
data/memory-presets.json
data/prompt-templates.json
data/user-facts.json
!data/.gitkeep

# ---------------------------------------------------------------------------
# Agent/tool workspaces and one-off repair artifacts
# ---------------------------------------------------------------------------
.claude/
.agents/
.codex/
.gemini/
.antigravity/
patches/
handoff/
agents/
patch_*.py
apply_*.ps1
repair_*.py
fix_*.py
force_fix_*.py

# ---------------------------------------------------------------------------
# Archives / binary bundles created during release or local testing
# ---------------------------------------------------------------------------
*.zip
*.7z
*.rar
*.tgz
*.tar
*.tar.gz

# ---------------------------------------------------------------------------
# Legacy broken git directory backups
# ---------------------------------------------------------------------------
.git.broken_*

# ---------------------------------------------------------------------------
# Editor / OS noise / scratch files
# ---------------------------------------------------------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*.log
*.tmp
*.bak
*.bak.*
*.bak-*
*.backup
*.backup*
d2utmp*
